# Public canonical URL used by sitemap and deployment metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to true only when every request is terminated by a correctly configured
# HTTPS edge. This enables HSTS and CSP upgrade-insecure-requests at build time.
KAIROMESH_TLS_EDGE=false

# Trust X-Forwarded-For for demo rate-limit partitioning only when a controlled
# reverse proxy overwrites that header before traffic reaches the app.
KAIROMESH_TRUST_PROXY=false

# Use a stable, base64-encoded 32-byte value when horizontally scaling
# deployments that use Next.js Server Actions. This demo has no Server Actions.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
